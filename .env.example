# ---------------------------------------------------------------------------
# Environment template for the Autonomous Data Governance Assistant.
# Copy this file to `.env` and fill in real values. Organizers / CI can also
# inject these as real environment variables; OS env always overrides files.
# ---------------------------------------------------------------------------

# How to resolve secrets:
#   - MODE=local : load COMPASS_API_KEY from a gitignored `.env.local` file
#                  (useful for local development).
#   - MODE=prod  : use the COMPASS_API_KEY value set directly in `.env`
#                  (organizers / CI inject the real key here).
MODE=prod

# Compass API (Core42)
COMPASS_API_KEY=your-compass-api-key-here
BASE_URL=https://api.core42.ai/v1

# Paths (defaults are fine for the bundled sample DB)
DATABASE_PATH=app/database/sample.db
DATABASE_DIR=app/database
DEFAULT_DB_NAME=sample
OUTPUT_DIR=app/outputs
LOG_DIR=logs

# App
LOG_LEVEL=INFO
