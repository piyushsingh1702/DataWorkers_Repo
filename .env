# Compass API Configuration
# MODE controls how COMPASS_API_KEY is resolved:
#   - MODE=local : load COMPASS_API_KEY (and any other override) from `.env.local`
#                  (gitignored). The value below is ignored.
#   - MODE=prod  : use the COMPASS_API_KEY value set directly in this file.
# When committing, leave MODE=local and keep COMPASS_API_KEY as a placeholder.
MODE=local
COMPASS_API_KEY=<COMPASS_API_KEY>

# BASE URLs
BASE_URL=https://api.core42.ai/v1
CHAT_BASE_URL=https://api.core42.ai/v1/chat/completions
EMBEDDING_BASE_URL=https://api.core42.ai/v1/embeddings
TRANSCRIPTIONS_BASE_URL=https://api.core42.ai/v1/audio/transcriptions
TRANSLATIONS_BASE_URL=https://api.core42.ai/v1/audio/translations
